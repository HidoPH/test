function CheckIfItsABuffRoom(stage)
	if alreadycheck or cooldowncheck then
		return false
	end
	cooldowncheck = true
	spawn(function()
		wait(2)
		cooldowncheck = false
	end)
	for i,v in pairs(getgc(true)) do
		if type(v) == "table" and rawget(v,"UseModel") and rawget(v,"IsActivated") and (v.IsCompleted)~= nil then
			if not v.IsCompleted and v.NodeIndex == stage  then
				local model = v.UseModel
				if model then
					alreadycheck = true
					if model.Name:find("Buff") then
						return true
					else
						return false
					end
				end
			end
		end
	end
	return false
end

