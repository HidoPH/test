function FindDoor()
	local Guidance = Maps:FindFirstChild("Guidance",true)
	if not Guidance then
		return
	end
	local list = {}
	local votedoor = Guidance:FindFirstAncestor("VoteDoor")
	local returnlist 
	if votedoor then
		for i,v in pairs(votedoor:GetChildren()) do
			local icon = v:FindFirstChild("IconImage",true)
			if icon then
				table.insert(list,
					{VoteDoor = votedoor, DoorModel = v, Door = v:FindFirstChildWhichIsA("TouchTransmitter",true).Parent, Image = icon.Image, DoorNumber = v}
				)
			end
		end
	end
	for i,v in pairs(PrioritizeIcons()) do
		for a,b in pairs(list) do
			if b.Image == v.Image then
				returnlist = b
				break
			end
		end
		if returnlist then 
			break
		end
	end
	if #list > 0 and not returnlist then
		returnlist= list[1]
	end
	return returnlist
end

