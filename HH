	function RunAutoRefine()
		if not weapontorefine then
			refinerunning = false
			refinereroll =false
			return
		end
		local slotid = GetSlotIdFromWeaponNameSummon(weapontorefine)
		if not slotid then
			refinerunning = false
			refinereroll =false
			return
		end
		repeat wait()
			if refinereroll then
				local code = game:GetService("ReplicatedStorage").EquipmentSystem.Remote.ApplyRefine:InvokeServer(slotid,1,"1001")
				if code == ErrorCode.SUCCEEDED then
					refinereroll = false
				else
					refinerunning = false
					refinereroll = false
				end
			end
		until not refinerunning
