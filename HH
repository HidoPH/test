function FindNearestAction()
	local dist = math.huge
	local nearest
	for i,v in pairs(Enemies:GetChildren()) do
		if v:GetAttribute("SpawnPointName") or (v:GetAttribute("MonsterId") and v:GetAttribute("MonsterId") == "60") then
			if v:GetAttribute("MonsterId") and v:GetAttribute("MonsterId") == "60" then
				donttp = true
			end
			if v:GetAttribute("IsDead") and v:GetAttribute("IsDead") == true then
				continue
			end
			local monster = v
			local model = monster:FindFirstChildWhichIsA("Model")
			if not model then
				continue
			end
			if model:GetAttribute("CurrAnimeStateName") and (model:GetAttribute("CurrAnimeStateName") == "Death" or model:GetAttribute("CurrAnimeStateName") == "") then
				continue
			end
			local hrt = monster:FindFirstChild("HumanoidRootPart",true)
			if not hrt then
				continue
			end
			local dis = (LP.Character.HumanoidRootPart.Position - hrt.Position).magnitude
			if dis < dist then
				dist = dis
				nearest = monster
			end
		end
	end
	return nearest
end
