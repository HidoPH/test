		local ground = v:FindFirstChild("Ground",true)
		if layout then
			layout:Destroy()
		end
		if ground then
			ground:Destroy()
		end
	end
	for i,v in pairs(Maps:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanCollide = false
		end
	end
