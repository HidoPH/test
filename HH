function NearestMap(monster)
	local HRT = LP.Character.HumanoidRootPart
	if monster then
		HRT = monster:FindFirstChild("HumanoidRootPart",true)
	end
	local nearest
	local nearestdis = math.huge
	if not HRT then
		return nearest
	end
	for i,v in pairs(Maps:GetChildren()) do
		local dis = (HRT.Position - v.WorldPivot.Position).Magnitude
		if dis < nearestdis then
			nearest = v
			nearestdis = dis
		end
	end
	if monster then
		local recycle = workspace.Recycle
		local dis = (HRT.Position - recycle.WorldPivot.Position).Magnitude
		if dis < nearestdis then
			nearest = recycle
			nearestdis = dis
		end
	end
	return nearest
end

