	function CheckIfLowQuality(info)
		if info.ExtraInfo and type(info.ExtraInfo) == "table" and info.ExtraInfo.EnhanceLevel ~= nil and info.ExtraInfo.EnhanceLevel >=1 then
			return false
		end
		if Armors[info.Id] then
			if tonumber(TraitConfig[info.ExtraInfo.EntryId].Rating) then -- Health TraitConfig[info.ExtraInfo.MainAttr].Rating == 1
				if TraitConfig[info.ExtraInfo.EntryId].Rating == 1 then
					return false
				else
					return true
				end
			end
		elseif Ornaments[info.Id] then
			if tonumber(Ornaments[info.Id].AttrPoolList[info.ExtraInfo.AttrIndex].AttrList[1].Rating) and tonumber(Ornaments[info.Id].AttrPoolList[info.ExtraInfo.AttrIndex].AttrList[2].Rating) then
				if Ornaments[info.Id].AttrPoolList[info.ExtraInfo.AttrIndex].AttrList[1].Rating == 1 then -- WALKSPEED >> and Ornaments[info.Id].AttrPoolList[info.ExtraInfo.AttrIndex].AttrList[2].Rating == 1 then
					return false
				else
					return true
				end
			end
		end
	end
