	function AddExpToWeapon(full,sell)
		local itemstosacrifice = {}
		for i,v in pairs(getgc(true)) do
			if type(v) == "table" and rawget(v,"GridList") then
				if v.BackpackType and v.BackpackType == "Equipment" then
					for a,b in pairs(v.GridList) do
						if b.Id and (((IncludeArmors or full) and (Armors[b.Id] or Ornaments[b.Id]) and CheckIfLowQuality(b)) or ((IncludeWeapons or full) and Weapons[b.Id] and Weapons[b.Id].Quality < 6)) and b.Like~=nil and b.Like == false  and b.IsEquip~=nil and b.IsEquip == false then
							itemstosacrifice[tostring(a)] = b.Num
						end
					end
				end
			end
		end
		if weapontoupgrade or full then
			local slot = GetSlotIdFromWeaponName(weapontoupgrade)
			if slot then
				game:GetService("ReplicatedStorage").EquipmentSystem.Remote.ApplyAddWeaponExp:InvokeServer(slot,1,itemstosacrifice)
			elseif full then
				game:GetService("ReplicatedStorage").Sell.Remote.ApplySell:InvokeServer("Equipment",itemstosacrifice)
			end
		end
	end
	function CycleQuest()
		local success,quests = GetPlayerAllQuestInfo:Invoke(Player)
		for i,v in pairs(quests) do
			if QuestConfig[i].Type == EnumCode.QuestType.Cycle and (v.State ~= EnumCode.QuestState.NoReceive) and (v.State ~= EnumCode.QuestState.Submitted) then
				local success,progress = GetQuestProgress:Invoke(Player,i)
				if QuestConfig[i].NumberProgress.FinsihGameDesignated == progress.FinsihGameDesignated then
					ApplyClaimCycleQuestReward:Invoke(i)
					CycleQuest()
					return
				else
					local code,status = game:GetService("ReplicatedStorage").Backpack.Bindable.IsBackpackFull:Invoke()
					if status == true then
						AddExpToWeapon(true,true)
					end
					StartDungeon(QuestConfig[i].Dungeon,QuestConfig[i].Difficulty)
				end
			end
		end
	end

