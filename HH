function CycleQuest()
	local success,quests = GetPlayerAllQuestInfo:Invoke(Player)
	for i,v in pairs(quests) do
		if QuestConfig[i].Type == EnumCode.QuestType.Cycle and (v.State ~= EnumCode.QuestState.NoReceive) and (v.State ~= EnumCode.QuestState.Submitted) then
			local success,progress = GetQuestProgress:Invoke(Player,i)
			if QuestConfig[i].NumberProgress.FinsihGameDesignated == progress.FinsihGameDesignated then
				ApplyClaimCycleQuestReward:Invoke(i)
				CycleQuest()
				return
			else
				local code,status = game:GetService("ReplicatedStorage").Backpack.Bindable.IsBackpackFull:Invoke()
				if status == true then
					AddExpToWeapon()
				end
				StartDungeon(QuestConfig[i].Dungeon,QuestConfig[i].Difficulty)
			end
		end
	end
end
