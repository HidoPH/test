function GetNameFromPriority(priority)
	for i,v in pairs(imageiconlist) do
		if v.Priority == priority then
			return v.Name
		end
	end
end

function ChangeItemPriorityTo(name,priority)
	for i,v in pairs(imageiconlist) do
		if v.Name == name then
			v.Priority = priority
			break
		end
	end
end
function GetSettingsValue(settingname,isanumber)
	if Settings[settingname] == nil then
		if not isanumber then 
			Settings[settingname] = false
		else
			Settings[settingname] = 0
		end
	end
	return Settings[settingname]
end
function ChangeSettings(settingname,setting)
	Settings[settingname] = setting
	SaveSettings()
end
function ChangePriority(priority,name)
	for i,v in pairs(imageiconlist) do
		if v.Name == name and v.Priority~=priority then
			local currentname = GetNameFromPriority(priority)
			ChangeItemPriorityTo(currentname,v.Priority)
			ChangeItemPriorityTo(name,priority)
		end
	end
	RefreshVotingLabels()
	SaveSettings()
end
