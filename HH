function GetBuffs()
	for i,v in pairs(getgc(true)) do
		if type(v) == "table" and rawget(v,"PredictionKey") then
			local t = v.GetSpecHandle
			local g = v.GetIsActive
			local go = v.GetOnwer
			if go and not buffslist.OwnerId then
				buffslist.OwnerId = v:GetOnwer()
			end
			if t and v.PredictionKey ~= 0 and g and v:GetIsActive() then
				local spec = v:GetSpecHandle()
				if spec~= "0" then
					table.insert(buffslist,{Spec = spec,Key = v.PredictionKey, Id = v.Id})
				end
			end
		end
	end
end

function AddExpToWeapon()
	local itemstosacrifice = {}
	for i,v in pairs(getgc(true)) do
		if type(v) == "table" and rawget(v,"GridList") then
			if v.BackpackType and v.BackpackType == "Equipment" then
				for a,b in pairs(v.GridList) do
					if b.Id and ((Armors[b.Id] or Ornaments[b.Id]) and CheckIfLowQuality(b)) and b.Like~=nil and b.Like == false  and b.IsEquip~=nil and b.IsEquip == false then
						itemstosacrifice[tostring(a)] = b.Num
					end
				end
			end
		end
	end
	for i,v in pairs(weapondata) do
		if WeaponsConfig[v.Id].Name == GetSettingsValue("WeaponToUpgrade") then
			game:GetService("ReplicatedStorage").EquipmentSystem.Remote.ApplyAddWeaponExp:InvokeServer(i,1,itemstosacrifice)
			return
		end
	end
	ApplySell:InvokeServer("Equipment",itemstosacrifice)
end


